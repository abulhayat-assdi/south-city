# ============================================================================
# South Dhaka Properties & Housing Ltd. — environment (spec §18)
# Copy to `.env` and fill in real secrets. NEVER commit `.env`.
# ============================================================================

# --- Database ---
# LOCAL DEV (docker-compose.dev.yml maps Postgres to localhost:5433):
DATABASE_URL="postgresql://southcity:southcity@localhost:5433/southcity?schema=public"
# PRODUCTION (inside docker-compose.yml, the db service host is `db`):
# DATABASE_URL="postgresql://sdph:<POSTGRES_PASSWORD>@db:5432/sdph"

# --- Auth.js / NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"          # prod: https://southdhaka.com.bd
AUTH_TRUST_HOST=true

# --- Production DB password (used by the prod docker-compose db service) ---
POSTGRES_PASSWORD="change-me-strong-password"

# --- File uploads (documents, media) — mounted volume in prod ---
UPLOAD_DIR="./uploads"

# --- Public site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"   # prod: https://southdhaka.com.bd
# 🔴 PLACEHOLDER — confirm the real WhatsApp business number (spec §21)
NEXT_PUBLIC_WHATSAPP="8801862534626"

# --- Seed: first ADMIN account (change the password after first login) ---
SEED_ADMIN_EMAIL="admin@southdhaka.com.bd"
SEED_ADMIN_PASSWORD="ChangeMe#2026"
