# ---- Lead form (Web3Forms) --------------------------------------------
# 🔴 Create a free access key at https://web3forms.com (takes 1 minute).
# Leads are emailed to the inbox you register the key with.
PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY

# ---- Sanity CMS (optional — site builds fine without it) ---------------
# 🔴 Create a project at https://sanity.io/manage, then set these here AND
# in Cloudflare Pages → Settings → Environment variables.
# Until they are set, the site builds from src/content/site.ts.
SANITY_PROJECT_ID=
SANITY_DATASET=production
