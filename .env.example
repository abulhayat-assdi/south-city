# --- Database (spec §17) ---
# Local dev via docker-compose.dev.yml maps Postgres to localhost:5433
DATABASE_URL="postgresql://southcity:southcity@localhost:5433/southcity?schema=public"

# --- Auth.js / NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Allow credential login over http in local dev; on HTTPS prod this is auto-handled by Caddy
AUTH_TRUST_HOST=true

# --- Production DB password (used by prod docker-compose) ---
POSTGRES_PASSWORD="change-me-strong-password"

# --- File uploads (documents, media) ---
UPLOAD_DIR="./uploads"

# --- Public site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="8801862534626"

# --- Seed: first ADMIN account (change password after first login) ---
SEED_ADMIN_EMAIL="admin@southcity.com.bd"
SEED_ADMIN_PASSWORD="ChangeMe#2026"
