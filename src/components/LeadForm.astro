---
/**
 * Lead capture (spec §6.12 / §9): 4 fields → Web3Forms email, no reload.
 * Honeypot for spam. "Send on WhatsApp instead" builds a prefilled wa.me link.
 */
import { ui, t, type Lang } from '../i18n/ui';
import { plots, settings, WEB3FORMS_KEY } from '../content';
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section id="contact" class="section-pad bg-navy-deep">
  <div class="container-c max-w-3xl">
    <SectionHeading
      eyebrow={t(ui.sections.contactEyebrow, lang)}
      title={t(ui.sections.contactTitle, lang)}
      light
      center
    >
      <p class="mx-auto mt-3 max-w-xl text-white/80">{t(ui.sections.contactSub, lang)}</p>
    </SectionHeading>

    <form
      id="lead-form"
      class="reveal rounded-2xl bg-white p-5 shadow-card sm:p-8"
      novalidate
      data-key={WEB3FORMS_KEY}
      data-wa={settings.whatsapp}
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="sm:col-span-1">
          <label for="lf-name" class="mb-1.5 block text-sm font-semibold text-navy">
            {t(ui.form.name, lang)} <span class="text-gold">*</span>
          </label>
          <input
            id="lf-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="h-12 w-full rounded-md border border-line px-3.5 text-base text-ink focus:border-gold"
          />
        </div>
        <div class="sm:col-span-1">
          <label for="lf-phone" class="mb-1.5 block text-sm font-semibold text-navy">
            {t(ui.form.phone, lang)} <span class="text-gold">*</span>
          </label>
          <input
            id="lf-phone"
            name="phone"
            type="tel"
            required
            inputmode="numeric"
            autocomplete="tel"
            placeholder={t(ui.form.phoneHint, lang)}
            class="h-12 w-full rounded-md border border-line px-3.5 text-base text-ink focus:border-gold"
          />
          <p id="lf-phone-err" class="mt-1 hidden text-sm text-red-600">
            {t(ui.form.invalidPhone, lang)}
          </p>
        </div>
        <div class="sm:col-span-1">
          <label for="lf-plot" class="mb-1.5 block text-sm font-semibold text-navy">
            {t(ui.form.plotSize, lang)}
          </label>
          <select
            id="lf-plot"
            name="plot_size"
            class="h-12 w-full rounded-md border border-line bg-white px-3 text-base text-ink focus:border-gold"
          >
            <option value="">{t(ui.form.plotAny, lang)}</option>
            {plots.map((p) => <option value={p.katha.en}>{t(p.katha, lang)}</option>)}
          </select>
        </div>
        <div class="sm:col-span-1">
          <label for="lf-msg" class="mb-1.5 block text-sm font-semibold text-navy">
            {t(ui.form.message, lang)}
          </label>
          <input
            id="lf-msg"
            name="message"
            type="text"
            class="h-12 w-full rounded-md border border-line px-3.5 text-base text-ink focus:border-gold"
          />
        </div>
      </div>

      <!-- honeypot (hidden from humans) -->
      <input
        type="checkbox"
        name="botcheck"
        class="hidden"
        style="display:none"
        tabindex="-1"
        autocomplete="off"
      />

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <button type="submit" id="lf-submit" class="btn-gold w-full" data-track="form_submit">
          {t(ui.form.submit, lang)}
        </button>
        <button type="button" id="lf-wa" class="btn-wa w-full" data-track="whatsapp_click">
          <Icon name="whatsapp" class="h-5 w-5" />
          {t(ui.form.orWhatsApp, lang)}
        </button>
      </div>
      <p id="lf-error" class="mt-3 hidden text-center text-sm font-medium text-red-600">
        {t(ui.form.error, lang)}
      </p>
    </form>

    <!-- success state -->
    <div
      id="lead-success"
      class="hidden rounded-2xl bg-white p-8 text-center shadow-card"
      role="status"
    >
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-whatsapp/15 text-whatsapp">
        <Icon name="check" class="h-8 w-8" strokeWidth={2.5} />
      </span>
      <h3 class="mt-4 text-2xl font-bold text-navy">{t(ui.form.successTitle, lang)}</h3>
      <p class="mt-2 text-muted">{t(ui.form.successBody, lang)}</p>
      <a
        href={`tel:${settings.phone}`}
        class="btn-outline mt-6"
        data-track="call_click"
      >
        <Icon name="phone" class="h-5 w-5" />
        {settings.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  if (form) {
    const lang = document.documentElement.lang as 'bn' | 'en';
    const phone = document.getElementById('lf-phone') as HTMLInputElement;
    const phoneErr = document.getElementById('lf-phone-err')!;
    const errBox = document.getElementById('lf-error')!;
    const submitBtn = document.getElementById('lf-submit') as HTMLButtonElement;
    const submitLabel = submitBtn.textContent;

    // Accept 01XXXXXXXXX / +8801XXXXXXXXX / 8801XXXXXXXXX (also Bangla digits)
    const normalize = (v: string) =>
      v
        .replace(/[০-৯]/g, (d) => String('০১২৩৪৫৬৭৮৯'.indexOf(d)))
        .replace(/[\s-]/g, '');
    const validPhone = (v: string) => /^(?:\+?880|0)1[3-9]\d{8}$/.test(normalize(v));

    const values = () => ({
      name: (document.getElementById('lf-name') as HTMLInputElement).value.trim(),
      phone: phone.value.trim(),
      plot: (document.getElementById('lf-plot') as HTMLSelectElement).value,
      msg: (document.getElementById('lf-msg') as HTMLInputElement).value.trim(),
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errBox.classList.add('hidden');
      const v = values();
      const phoneOk = validPhone(v.phone);
      phoneErr.classList.toggle('hidden', phoneOk);
      if (!form.reportValidity() || !phoneOk) return;

      submitBtn.disabled = true;
      submitBtn.textContent = lang === 'bn' ? 'পাঠানো হচ্ছে…' : 'Sending…';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            access_key: form.dataset.key,
            subject: `South City lead: ${v.name} (${v.plot || 'plot size undecided'})`,
            from_name: 'South City Website',
            name: v.name,
            phone: normalize(v.phone),
            plot_size: v.plot || 'Not sure yet',
            message: v.msg,
            botcheck: (form.querySelector('[name="botcheck"]') as HTMLInputElement).checked,
          }),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        form.classList.add('hidden');
        document.getElementById('lead-success')?.classList.remove('hidden');
      } catch {
        errBox.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    });

    // WhatsApp fallback with prefilled details
    document.getElementById('lf-wa')?.addEventListener('click', () => {
      const v = values();
      const text =
        lang === 'bn'
          ? `আসসালামু আলাইকুম, আমি ${v.name || ''}${v.plot ? `, ${v.plot} প্লটে আগ্রহী` : ', সাউথ সিটির প্লটে আগ্রহী'}। ${v.msg}`.trim()
          : `Assalamu Alaikum, I'm ${v.name || 'interested'}${v.plot ? `, interested in a ${v.plot} plot` : ' in South City plots'}. ${v.msg}`.trim();
      window.open(
        `https://wa.me/${form.dataset.wa}?text=${encodeURIComponent(text)}`,
        '_blank',
        'noopener'
      );
    });
  }
</script>
