---
/**
 * Trust row — verifiable claims only.
 * 🔴 Spec §6.4/§10: NO "RAJUK Approved" badge, NO REHAB logo on this site.
 */
import { ui, t, type Lang } from '../i18n/ui';
import { trustBadges } from '../content';
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section class="section-pad bg-navy-deep">
  <div class="container-c">
    <SectionHeading
      eyebrow={t(ui.sections.trustEyebrow, lang)}
      title={t(ui.sections.trustTitle, lang)}
      light
      center
    />
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6 sm:gap-4" role="list">
      {
        trustBadges.map((b) => (
          <li class="reveal flex flex-col items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-3 py-6 text-center">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-gold/15 text-gold-light">
              <Icon name={b.icon} class="h-6 w-6" />
            </span>
            <span class="text-sm font-semibold leading-snug text-white">{t(b.label, lang)}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
