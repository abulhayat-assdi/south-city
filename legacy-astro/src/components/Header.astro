---
import { ui, t, altPath, type Lang } from '../i18n/ui';
import { settings } from '../content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav = [
  { href: '#overview', label: ui.nav.overview },
  { href: '#master-plan', label: ui.nav.masterplan },
  { href: '#plots', label: ui.nav.plots },
  { href: '#location', label: ui.nav.location },
  { href: '#amenities', label: ui.nav.amenities },
  { href: '#contact', label: ui.nav.contact },
];
const other = altPath(lang);
const otherLang = lang === 'bn' ? 'en' : 'bn';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 h-14 bg-white transition-shadow duration-300 md:h-[72px]"
>
  <div class="container-c flex h-full items-center justify-between gap-4">
    <!-- wordmark -->
    <a href={lang === 'bn' ? '/' : '/en/'} class="flex shrink-0 items-center gap-2.5" aria-label="South City — home">
      <svg viewBox="0 0 48 48" class="h-9 w-9" aria-hidden="true">
        <circle cx="24" cy="24" r="22" fill="#14245C"></circle>
        <circle cx="24" cy="24" r="22" fill="none" stroke="#C9A227" stroke-width="2.5"></circle>
        <text
          x="24"
          y="31"
          text-anchor="middle"
          font-family="Georgia, serif"
          font-size="17"
          font-weight="700"
          fill="#E2C56B">SD</text
        >
      </svg>
      <span class="font-display leading-tight">
        <span class="block text-lg font-extrabold tracking-wide text-navy">SOUTH CITY</span>
        <span class="block text-[10px] font-medium uppercase tracking-[0.14em] text-gold"
          >South Dhaka Properties &amp; Housing Ltd.</span
        >
      </span>
    </a>

    <!-- desktop nav -->
    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="nav-link font-display text-[15px] font-semibold text-navy transition-colors hover:text-gold"
            data-spy={item.href.slice(1)}
          >
            {t(item.label, lang)}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <!-- language toggle -->
      <a
        href={other}
        class="lang-toggle inline-flex min-h-[40px] items-center gap-1.5 rounded-md border border-line px-3 font-display text-sm font-semibold text-navy hover:border-gold"
        data-set-lang={otherLang}
        aria-label={t(ui.header.langLabel, lang)}
      >
        <Icon name="globe" class="h-4 w-4 text-gold" />
        {t(ui.header.langShort, lang)}
      </a>

      <!-- desktop call button -->
      <a
        href={`tel:${settings.phone}`}
        class="btn-gold hidden !min-h-[44px] !px-5 !py-2 md:inline-flex"
        data-track="call_click"
      >
        <Icon name="phone" class="h-4 w-4" />
        {t(ui.header.callNow, lang)}
      </a>

      <!-- hamburger -->
      <button
        id="menu-btn"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-md text-navy lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t(ui.header.menuOpen, lang)}
      >
        <Icon name="menu" class="menu-open h-7 w-7" />
        <Icon name="x" class="menu-close hidden h-7 w-7" />
      </button>
    </div>
  </div>

  <!-- mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden absolute inset-x-0 top-full max-h-[calc(100dvh-56px)] overflow-y-auto bg-navy shadow-2xl lg:!hidden"
  >
    <div class="container-c flex flex-col py-4">
      <a
        href={other}
        class="mb-2 inline-flex min-h-[48px] items-center gap-2 border-b border-white/15 pb-3 font-display text-base font-semibold text-gold-light"
        data-set-lang={otherLang}
      >
        <Icon name="globe" class="h-5 w-5" />
        {t(ui.header.langLabel, lang)}
      </a>
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="drawer-link flex min-h-[48px] items-center border-b border-white/10 text-lg font-semibold text-white transition-colors hover:text-gold-light"
            data-spy={item.href.slice(1)}
          >
            {t(item.label, lang)}
          </a>
        ))
      }
      <a
        href={`tel:${settings.phone}`}
        class="btn-gold mt-4"
        data-track="call_click"
      >
        <Icon name="phone" class="h-5 w-5" />
        {t(ui.header.callNow, lang)} · {settings.phoneDisplay}
      </a>
    </div>
  </div>
</header>

<!-- spacer so content clears the fixed header -->
<div class="h-14 md:h-[72px]" aria-hidden="true"></div>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const openIcon = btn.querySelector('.menu-open')!;
  const closeIcon = btn.querySelector('.menu-close')!;

  const setMenu = (open: boolean) => {
    menu.classList.toggle('hidden', !open);
    openIcon.classList.toggle('hidden', open);
    closeIcon.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));
  };
  btn.addEventListener('click', () => setMenu(menu.classList.contains('hidden')));
  menu.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setMenu(false);
  });
  document.addEventListener('click', (e) => {
    if (!header.contains(e.target as Node)) setMenu(false);
  });

  // shadow after 40px scroll
  const onScroll = () => header.classList.toggle('shadow-header', window.scrollY > 40);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // remember explicit language choice
  document.querySelectorAll<HTMLElement>('[data-set-lang]').forEach((el) =>
    el.addEventListener('click', () => {
      try {
        localStorage.setItem('sc-lang', el.dataset.setLang!);
      } catch (e) {}
    })
  );

  // scroll-spy: highlight the section currently in view
  const links = document.querySelectorAll<HTMLElement>('[data-spy]');
  const sections = [...new Set([...links].map((l) => l.dataset.spy!))]
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];
  const spy = new IntersectionObserver(
    (entries) => {
      for (const en of entries) {
        if (!en.isIntersecting) continue;
        links.forEach((l) =>
          l.classList.toggle('!text-gold', l.dataset.spy === en.target.id)
        );
      }
    },
    { rootMargin: '-30% 0px -60% 0px' }
  );
  sections.forEach((s) => spy.observe(s));
</script>
